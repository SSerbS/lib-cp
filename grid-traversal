const int dx[] = {1,0,0,-1};
const int dy[] = {0,1,-1,0};

bool valid (int x, int y, int n, int m){
  return x>=0 && x < n && y >= 0 && y < m && grid[x][y] != '#';
}

void rec(int x, int y){
  grid[x][y] = '#';
  for(int d = 0; d < 4; d++){
    int ax = x + dx[d], ay = y + dy[d];
    if(!valid(ax,ay)) continue;
    rec(ax,ay);
  }
}
